rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isMasterAdmin() {
      return hasUserDoc() && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true
        || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
        || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin_master'
        || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superAdmin'
        || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super-admin'
        || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }

    function userRole() {
      return hasUserDoc()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function userGroupId() {
      return hasUserDoc()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.groupId
        : null;
    }

    function isGroupAdmin(groupId) {
      return hasUserDoc() && (
        userRole() == 'group'
        || userRole() == 'group-admin'
        || userRole() == 'admin_group'
        || userRole() == 'admin_groupe'
      ) && userGroupId() == groupId;
    }

    function isPhotographerOwner(photographerId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/photographers/$(photographerId))
        && firestore.get(/databases/(default)/documents/photographers/$(photographerId)).data.ownerUid == request.auth.uid;
    }

    function canManageMarketplaceMedia(photographerId) {
      return isMasterAdmin() || isPhotographerOwner(photographerId);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidImageType() {
      return request.resource != null
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif|heic|heif)');
    }

    function isValidImageSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function hasValidPhotographerReservation(photographerId, eventId, galleryId, fileName) {
      let reservationId = request.resource.metadata.reservationId;
      let reservationPath = /databases/(default)/documents/media_upload_reservations/$(reservationId);
      return isAuthenticated()
        && request.resource.metadata != null
        && reservationId is string
        && reservationId.size() > 0
        && firestore.exists(reservationPath)
        && firestore.get(reservationPath).data.status == 'reserved'
        && firestore.get(reservationPath).data.ownerUid == request.auth.uid
        && firestore.get(reservationPath).data.photographerId == photographerId
        && firestore.get(reservationPath).data.galleryId == galleryId
        && firestore.get(reservationPath).data.eventId == eventId
        && firestore.get(reservationPath).data.photoId == request.resource.metadata.photoId
        && firestore.get(reservationPath).data.originalPath == 'photographers/' + photographerId + '/events/' + eventId + '/galleries/' + galleryId + '/originals/' + fileName
        && request.resource.size > 0
        && request.resource.size <= firestore.get(reservationPath).data.maxFileBytes
        && request.resource.size <= firestore.get(reservationPath).data.sizeBytes;
    }

    match /users/{userId}/profile/{imageId} {
      allow read: if true;
      allow write: if isOwner(userId)
                    && isValidImageType()
                    && isValidImageSize();
      allow delete: if isOwner(userId);
    }

    match /groups/{groupId}/{allPaths=**} {
      allow read: if true;
      allow write: if (isMasterAdmin() || isGroupAdmin(groupId))
                    && isValidImageType()
                    && isValidImageSize();
      allow delete: if isMasterAdmin() || isGroupAdmin(groupId);
    }

    match /places/{placeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMasterAdmin()
                    && isValidImageType()
                    && isValidImageSize();
      allow delete: if isMasterAdmin();
    }

    match /shops/{shopId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMasterAdmin()
                    && isValidImageType()
                    && isValidImageSize();
      allow delete: if isMasterAdmin();
    }

    match /products/{shopId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMasterAdmin()
                    && isValidImageType()
                    && isValidImageSize();
      allow delete: if isMasterAdmin();
    }

    match /media/{scopeId}/{allPaths=**} {
      allow read: if isMasterAdmin();
      allow write: if isMasterAdmin()
                    && isValidImageType()
                    && isValidImageSize();
      allow delete: if isMasterAdmin();
    }

    // Les originaux ne sont jamais publics. Le client ne peut envoyer un fichier
    // qu'après une réservation serveur liée au photographe, à la galerie et au quota.
    match /photographers/{photographerId}/events/{eventId}/galleries/{galleryId}/originals/{fileName} {
      allow read: if canManageMarketplaceMedia(photographerId);
      allow create, update: if canManageMarketplaceMedia(photographerId)
                            && isValidImageType()
                            && request.resource.size <= 70 * 1024 * 1024
                            && hasValidPhotographerReservation(
                              photographerId,
                              eventId,
                              galleryId,
                              fileName
                            );
      allow delete: if canManageMarketplaceMedia(photographerId);
    }

    // Les dérivés sont générés uniquement par Cloud Functions avec Admin SDK.
    // Ils sont consultables publiquement dans la boutique, contrairement aux originaux.
    match /photographers/{photographerId}/events/{eventId}/galleries/{galleryId}/thumbs/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /photographers/{photographerId}/events/{eventId}/galleries/{galleryId}/previews/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /photographers/{photographerId}/events/{eventId}/galleries/{galleryId}/watermarked/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
