{
  "rule": [
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 1,
        "matchesPrefix": ["photo-uploads-temp/"]
      }
    },
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 7,
        "matchesPrefix": ["photo-rejected/", "photo-trash/"]
      }
    }
  ]
}
