# Stripe Secret Key
# Get it from: https://dashboard.stripe.com/apikeys
# Set deployed functions with: firebase functions:secrets:set STRIPE_SECRET_KEY
# Use process.env only as a local fallback for tests or emulators

STRIPE_SECRET_KEY=__SET_IN_SECRET_MANAGER_ONLY__

# Stripe Webhook Secret
# Get it from: https://dashboard.stripe.com/webhooks
# Set deployed functions with: firebase functions:secrets:set STRIPE_WEBHOOK_SECRET

STRIPE_WEBHOOK_SECRET=__SET_IN_SECRET_MANAGER_ONLY__
