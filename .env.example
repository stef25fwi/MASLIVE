# Mapbox Configuration
# Get your token from: https://account.mapbox.com/tokens/
MAPBOX_PUBLIC_TOKEN=pk_your_public_token_here

# Firebase Configuration (optional - for reference)
FIREBASE_PROJECT_ID=maslive

# Stripe (client / build front)
# Clé PUBLIABLE Stripe (pk_test_... ou pk_live_...). Requise pour la PaymentSheet
# native iOS/Android. Injectée au build via --dart-define par les scripts de deploy.
# Le web n'en a pas besoin (paiement via Stripe Checkout en redirection).
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Identifiant marchand Apple Pay (optionnel, pour Apple Pay dans la PaymentSheet).
STRIPE_APPLE_MERCHANT_ID=merchant.com.maslive
